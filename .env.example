# Echo GPT Monorepo
# Copy to .env and fill in your values

# Cloud API
CLOUD_API_PORT=4000
CLOUD_API_JWT_SECRET=change-me-to-a-random-secret
CLOUD_API_JWT_EXPIRES_IN=15m
CLOUD_API_JWT_REFRESH_EXPIRES_IN=7d
CLOUD_API_DB_PATH=./data/echo.db
CLOUD_API_CORS_ORIGIN=http://localhost:5173

# AI Gateway
AI_GATEWAY_PORT=4001
AI_GATEWAY_CORS_ORIGIN=http://localhost:5173

# AI Provider Keys (optional — only configure what you use)
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GEMINI_API_KEY=
DEEPSEEK_API_KEY=
OPENROUTER_API_KEY=
OLLAMA_BASE_URL=http://localhost:11434

# Rate Limiting
RATE_LIMIT_REQUESTS=60
RATE_LIMIT_TOKENS=100000

# Push Notifications (optional)
FCM_SERVER_KEY=
FCM_API_URL=https://fcm.googleapis.com/fcm/send
APNS_KEY_ID=
VAPID_PUBLIC_KEY=

# MinIO (S3-compatible local storage)
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin
MINIO_ENDPOINT=http://localhost:9000
MINIO_BUCKET=echo-files
