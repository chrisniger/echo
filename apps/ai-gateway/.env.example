[TEMPLATE]
PORT=4001
CORS_ORIGIN=http://localhost:5173,http://localhost:3000,http://tauri.localhost,tauri://localhost,https://tauri.localhost,http://localhost:1420

# JWT secret used to validate access tokens from the desktop app.
# Must match the Cloud API's JWT_SECRET.
JWT_SECRET=dev-secret-change-in-production

# Shared API key for server-to-server calls from the Cloud API.
# The Cloud API must set the same value in AI_GATEWAY_API_KEY.
AI_GATEWAY_API_KEY=change-me-in-production

OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GEMINI_API_KEY=
DEEPSEEK_API_KEY=
OPENROUTER_API_KEY=

# Groq (Free OpenAI-compatible Whisper API — used for transcription)
# Get a free key at https://console.groq.com/keys
GROQ_API_KEY=
GROQ_WHISPER_MODEL=whisper-large-v3
OLLAMA_BASE_URL=http://localhost:11434

RATE_LIMIT_REQUESTS=60
RATE_LIMIT_TOKENS=100000
