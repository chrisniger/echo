PORT=4000
JWT_SECRET=change-me-to-a-random-secret
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d
DB_PATH=./data/echo.db
CORS_ORIGIN=http://localhost:5173,http://localhost:3000,http://tauri.localhost,tauri://localhost,https://tauri.localhost,http://localhost:1420

# Stripe (optional)
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# Email (optional — uses console log if not configured)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=noreply@echo-gpt.app

# Sentry (optional)
SENTRY_DSN=

# App
APP_URL=http://localhost:5173
APP_VERSION=0.1.0
UPDATE_DOWNLOAD_URL=
UPDATE_SIGNATURE=
UPDATE_NOTES=

# Push Notifications (optional — leave blank to skip)
FCM_SERVER_KEY=
FCM_API_URL=https://fcm.googleapis.com/fcm/send
APNS_KEY_ID=
VAPID_PUBLIC_KEY=

