{
  "name": "@echo-gpt/cloud-api",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "predev": "pnpm --filter @echo-gpt/shared-types build",
    "dev": "tsx watch src/index.ts",
    "prebuild": "pnpm --filter @echo-gpt/shared-types build",
    "build": "tsc",
    "start": "node dist/index.js",
    "pretest": "pnpm --filter @echo-gpt/shared-types build",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "lint": "eslint src"
  },
  "dependencies": {
    "@echo-gpt/shared-config": "workspace:*",
    "@echo-gpt/shared-types": "workspace:*",
    "bcryptjs": "^2.4.3",
    "better-sqlite3": "^11.0.0",
    "bonjour-service": "^1.2.0",
    "cors": "^2.8.5",
    "dotenv": "^16.4.0",
    "express": "^5.0.0",
    "helmet": "^8.0.0",
    "jsonwebtoken": "^9.0.0",
    "multer": "^1.4.5-lts.1",
    "mammoth": "^1.9.0",
    "nodemailer": "^9.0.3",
    "pdf-parse": "^1.1.1",
    "stripe": "^22.3.0",
    "uuid": "^11.0.0",
    "web-push": "^3.6.7",
    "ws": "^8.21.0",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/better-sqlite3": "^7.6.12",
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.0",
    "@types/jsonwebtoken": "^9.0.7",
    "@types/multer": "^1.4.11",
    "@types/nodemailer": "^8.0.1",
    "@types/uuid": "^10.0.0",
    "@types/web-push": "^3.6.3",
    "@types/ws": "^8.18.1",
    "@types/supertest": "^6.0.2",
    "supertest": "^7.0.0",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0",
    "vitest": "^2.1.9"
