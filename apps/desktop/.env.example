[TEMPLATE]
VITE_CLOUD_API_URL=http://localhost:4000
VITE_GATEWAY_API_URL=http://localhost:4001

# VITE_DEFAULT_IMAGE_MODEL - model used by chatService as the target
# for the screenshot -> /chat pipeline when the user-selected model
# is text-only (or otherwise outside VISION_CAPABLE_MODELS). Must be
# one of the AiModel literal-union members marked vision-capable in
# packages/shared-config/src/providers.ts (e.g. gpt-4o, gpt-4o-mini,
# claude-3.5-sonnet, gemini-2.0-pro, qwen-vl-max, etc.).
#
#   - Unset or empty  -> PREFERRED_VISION_FALLBACK (currently 'gpt-4o-mini').
#   - Set + valid     -> that model.
#   - Set + invalid   -> PREFERRED_VISION_FALLBACK + a one-time console.warn.
VITE_DEFAULT_IMAGE_MODEL=gpt-4o-mini
