{
  "$schema": "https://raw.githubusercontent.com/nicehash/tauri/dev/crates/tauri-utils/schema.json",
  "productName": "Echo GPT",
  "version": "0.1.0",
  "identifier": "com.echo-gpt.desktop",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "devUrl": "http://localhost:5173",
    "beforeBuildCommand": "pnpm build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Echo GPT",
        "width": 1200,
        "height": 800,
        "minWidth": 800,
        "minHeight": 600,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": "default-src 'self'; script-src 'self' 'unsafe-eval'; style-src 'self' 'unsafe-inline'; img-src 'self' data: asset: https://*.s3.amazonaws.com; connect-src 'self' http://localhost:4000 http://localhost:4001 ws://localhost:*"
    },
    "trayIcon": {
      "iconPath": "icons/32x32.png",
      "iconAsTemplate": true
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": ["icons/32x32.png", "icons/128x128.png", "icons/128x128@2x.png", "icons/icon.ico"],
    "windows": {
      "wix": null,
      "nsis": null
    },
    "macOS": {
      "minimumSystemVersion": "10.15"
    },
    "linux": {
      "deb": {},
      "appimage": {}
    }
  },
  "plugins": {
    "updater": {
      "active": true,
      "endpoints": ["http://localhost:4000/api/updates"],
      "pubkey": ""
    },
    "global-shortcut": {
      "shortcuts": {
        "hideApp": "Ctrl+Shift+H",
        "askEcho": "Ctrl+Shift+Space",
        "screenshot": "Ctrl+Shift+S"
      }
    }
  }
}
